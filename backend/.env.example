# ─── The Prism · Environment Configuration ───────────────────────────────────
# Copy this file to .env and fill in your values.

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="The Prism"
APP_VERSION="1.0.0"
DEBUG=false

# ── API ───────────────────────────────────────────────────────────────────────
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Optional: set to access gated models (e.g. LLaMA-3)
HF_TOKEN=
# Local cache directory for downloaded model configs / weights
HF_CACHE_DIR=~/.prism/models

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# CHANGE THIS to a long random string in production!
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080   # 7 days

# ── License ───────────────────────────────────────────────────────────────────
LICENSE_SERVER_URL=https://license.buildmaxxing.com
# Set to "offline" to skip remote verification (dev/air-gapped mode)
LICENSE_MODE=online

# ── Stripe (Phase 6) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# ── Vector DB (Phase 5) ───────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Alternative: use embedded ChromaDB (no separate process)
VECTOR_BACKEND=qdrant
